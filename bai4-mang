<!DOCTYPE html>
<html>
<body>
<script>
    let diemLop = [7, 9, 4, 8, 6, 10, 3, 5];

    console.log("Số lượng học viên trong lớp: " + diemLop.length);

    let tongDiem = 0;
    for (let i = 0; i < diemLop.length; i++) {
        tongDiem += diemLop[i];
    }
    let diemTrungBinh = tongDiem / diemLop.length;
    console.log("Tổng điểm của lớp: " + tongDiem);
    console.log("Điểm trung bình của lớp: " + diemTrungBinh);

    let maxDiem = diemLop[0];
    let minDiem = diemLop[0];
    for (let i = 1; i < diemLop.length; i++) {
        if (diemLop[i] > maxDiem) maxDiem = diemLop[i];
        if (diemLop[i] < minDiem) minDiem = diemLop[i];
    }
    console.log("Điểm cao nhất: " + maxDiem);
    console.log("Điểm thấp nhất: " + minDiem);

    let soHocVienDat = 0;
    for (let i = 0; i < diemLop.length; i++) {
        if (diemLop[i] >= 5) {
            soHocVienDat++;
        }
    }
    console.log("Số học viên đạt: " + soHocVienDat);
</script>
</body>
</html>
